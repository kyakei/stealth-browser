# Copy to server/.env (gitignored). Server loads via dotenv on startup.

# 2captcha API key — only needed if you use the captcha-solver tools.
# Get one at https://2captcha.com — pay-as-you-go, ~$0.003 per reCAPTCHA v2 solve.
TWOCAPTCHA_API_KEY=

# Optional overrides (mostly already configurable via server/config/default.json):
# HTTP_PORT=7331
# WS_PORT=7332
# LOG_LEVEL=info
# BROWSER_HEADLESS=false
